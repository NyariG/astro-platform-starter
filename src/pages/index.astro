---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nyári Terv - Fejlesztés alatt">
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
        <h1 class="text-4xl font-bold mb-4">Nyári Terv</h1>
        <h2 class="text-2xl text-gray-600 mb-8">Épületgépészeti Tervezés</h2>
        
        <div class="bg-blue-50 border-l-4 border-blue-500 p-6 mb-8 max-w-2xl">
            <p class="text-lg text-blue-700 italic">
                "Weboldalunk megújul, hogy hamarosan még pontosabb információkkal segíthessük épületgépészeti projektjeit."
            </p>
        </div>

        <div class="space-y-4">
            <p class="text-xl font-semibold">Kapcsolat és ajánlatkérés:</p>
            <p class="text-lg">📧 <a href="mailto:info@nyariterv.hu" class="text-blue-600 hover:underline">info@nyariterv.hu</a></p>
            <p class="text-lg">📞 <a href="tel:+36703187843" class="text-blue-600 hover:underline">+36 70/3187843</a></p>
        </div>

        <div class="mt-12 text-sm text-gray-400">
            <p>Engedélyezési tervek • Kiviteli tervek • Műszaki tanácsadás</p>
        </div>
    </div>
</Layout>
