---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroBg from '../assets/hero-bg.png';
import planningImg from '../assets/planning.jpg';

const services = [
    {
        title: "Családi Házak",
        description: "Teljes körű gépészeti tervezés új építésű és felújítandó családi házakhoz. Energiahatékony, modern megoldások személyre szabva.",
        iconPath: "M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25",
        features: ["Fűtés és hűtés", "Szellőztető rendszerek", "Víz- és csatornahálózat", "Hőszivattyús rendszerek"]
    },
    {
        title: "Társasházak",
        description: "Többlakásos épületek komplex gépészeti tervezése. Rendszerszintű gondolkodás, gazdaságos üzemeltetés és precíz kivitelezési tervek.",
        iconPath: "M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5M12 6.75h1.5M15 6.75h1.5M9 10.5h1.5M12 10.5h1.5M15 10.5h1.5M9 14.25h1.5M12 14.25h1.5M15 14.25h1.5M9 18h1.5M12 18h1.5M15 18h1.5",
        features: ["Központi gépészet", "Egyedi mérési megoldások", "Tűzvédelmi rendszerek", "Szennyvíz elvezetés"]
    }
];

const systems = [
    "Fűtés", "Hűtés", "Szellőzés", "Vízellátás", "Szennyvíz", "Esővíz elvezetés"
];
---

<Layout title="Nyári Terv – Precíz épületgépészeti tervezés">
    <!-- Hero Section -->
    <section class="relative bg-slate-50 overflow-hidden">
        <div class="absolute inset-0">
            <Image src={heroBg} alt="Épületgépészeti tervek" class="w-full h-full object-cover opacity-20" />
        </div>
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#2563eb_1px,transparent_1px)] [background-size:16px_16px]"></div>
        <div class="container-custom relative z-10 py-24 sm:py-32 lg:pb-40">
            <div class="mx-auto max-w-2xl text-center">
                <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-6xl mb-6">
                    Nyári Terv <span class="block text-primary text-2xl sm:text-4xl mt-2 font-medium">Precíz épületgépészeti tervezés Győrben és környékén</span>
                </h1>
                <p class="mt-6 text-lg leading-8 text-slate-600">
                    Fűtés, hűtés, szellőzés, víz, szennyvíz és esővíz rendszerek tervezése, különös tekintettel a hőszivattyús megoldásokra.
                </p>
                <div class="mt-10 flex items-center justify-center gap-x-6">
                    <a href="#kapcsolat" class="btn text-base px-8 py-3">
                        Ajánlatkérés
                    </a>
                    <a href="#szolgaltatasok" class="text-sm font-semibold leading-6 text-slate-900 hover:text-primary transition">
                        Szolgáltatások megtekintése <span aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="szolgaltatasok" class="section bg-white">
        <div class="container-custom">
            <div class="mx-auto max-w-2xl text-center mb-16">
                <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Szolgáltatásaink</h2>
                <p class="mt-4 text-lg text-slate-600">
                    Mérnöki precizitással tervezünk, legyen szó magánszemélyekről vagy beruházókról.
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
                {services.map((service) => (
                    <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:shadow-lg transition-shadow duration-300">
                        <div class="text-primary mb-6">
                            <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d={service.iconPath} />
                            </svg>
                        </div>
                        <h3 class="text-2xl font-bold text-slate-900 mb-4">{service.title}</h3>
                        <p class="text-slate-600 mb-6 leading-relaxed">
                            {service.description}
                        </p>
                        <ul class="space-y-3">
                            {service.features.map((feature) => (
                                <li class="flex items-center text-slate-700">
                                    <svg class="h-5 w-5 text-primary mr-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    {feature}
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Detailed Systems Section -->
    <section class="section bg-slate-900 text-white">
        <div class="container-custom">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-6 text-white">
                        Korszerű Rendszerek Tervezése
                    </h2>
                    <p class="text-slate-300 text-lg mb-8 leading-relaxed">
                        A modern épületgépészet nem csak a csövekről szól. Energiahatékony, fenntartható és kényelmes otthonokat tervezünk. Kiemelt figyelmet fordítunk a <strong>hőszivattyús megoldásokra</strong>, melyek a jövő zálogai.
                    </p>
                    <div class="grid grid-cols-2 gap-4">
                        {systems.map((system) => (
                            <div class="flex items-center gap-3 p-3 bg-slate-800 rounded-lg">
                                <div class="h-2 w-2 rounded-full bg-primary"></div>
                                <span class="font-medium">{system}</span>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="relative h-64 lg:h-96 rounded-2xl overflow-hidden bg-slate-800 flex items-center justify-center border border-slate-700">
                    <Image src={planningImg} alt="Tervezés folyamatban" class="w-full h-full object-cover" />
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="kapcsolat" class="section bg-blue-50">
        <div class="container-custom">
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
                <div class="grid grid-cols-1 lg:grid-cols-2">
                    <div class="p-8 sm:p-12 lg:p-16">
                        <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-6">Lépjen velünk kapcsolatba!</h2>
                        <p class="text-lg text-slate-600 mb-8">
                            Kérjen ajánlatot vagy egyeztessen időpontot konzultációra. Állunk rendelkezésére Győrben és vonzáskörzetében.
                        </p>
                        
                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="bg-blue-100 p-3 rounded-lg text-primary">
                                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-slate-900">Email</h3>
                                    <a href="mailto:info@nyariterv.hu" class="text-primary hover:underline">info@nyariterv.hu</a>
                                </div>
                            </div>
                            
                            <div class="flex items-start gap-4">
                                <div class="bg-blue-100 p-3 rounded-lg text-primary">
                                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                                    </svg>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-slate-900">Telefon</h3>
                                    <a href="tel:+36703187843" class="text-primary hover:underline">+36 70 318 7843</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-slate-100 flex flex-col justify-center items-center p-8 text-center">
                        <h3 class="text-xl font-semibold mb-4 text-slate-800">Miben segíthetünk?</h3>
                        <p class="text-slate-600 mb-8 max-w-sm">
                            Gépészeti tervezés engedélyezéshez, kivitelezéshez vagy tanácsadás.
                        </p>
                        <a href="mailto:info@nyariterv.hu" class="btn w-full max-w-xs">
                            Írjon nekünk
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
