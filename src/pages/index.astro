---
import Layout from '../layouts/Layout.astro';
import Markdown from '../components/Markdown.astro';

// Itt definiálod a bemutatkozó szöveget
const explainer = `
Precíz épületgépészeti tervezés, műszaki tanácsadás és engedélyeztetés. 
Segítek megvalósítani modern, energiatakarékos fűtési, vízellátási és csatornázási rendszereit, legyen szó családi házról vagy ipari létesítményről.
`;
---

<Layout title="Nyári Terv - Épületgépészeti Tervezés">
    <h1 class="mb-10">Nyári Terv – Mérnöki Szolgáltatások</h1>
    <Markdown content={explainer} class="mb-10 text-lg" />
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        <div class="p-4 border rounded shadow-sm">
            <h3 class="font-bold">Tervezés</h3>
            <p>Víz-, gáz-, fűtés- és légtechnikai rendszerek teljes körű tervezése.</p>
        </div>
        <div class="p-4 border rounded shadow-sm">
            <h3 class="font-bold">Engedélyeztetés</h3>
            <p>Gáztervek és közműnyilatkozatok ügyintézése a szolgáltatóknál.</p>
        </div>
    </div>

    <p>
        <a href="mailto:info@nyariterv.hu" class="btn btn-lg sm:min-w-64">Ajánlatot kérek</a>
    </p>
</Layout>
