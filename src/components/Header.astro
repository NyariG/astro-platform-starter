---
import Logo from '../components/Logo.astro';

const navItems = [
    { linkText: 'Kezdőlap', href: '/' },
    { linkText: 'Szolgáltatások', href: '/#szolgaltatasok' },
    { linkText: 'Energetikai Tanúsítvány', href: '/energetikai-tanusitvany' },
    { linkText: 'Kapcsolat', href: '/#kapcsolat' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/60">
    <div class="container-custom flex h-16 items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-slate-900 hover:text-primary transition">
            <Logo />
             <span class="text-primary">Nyári</span>Terv
        </a>
        
        <nav class="hidden md:flex gap-6">
            {navItems.map((item) => (
                <a href={item.href} class="text-sm font-semibold leading-6 text-slate-900 hover:text-primary transition">
                    {item.linkText}
                </a>
            ))}
        </nav>

        <div class="flex items-center gap-4">
            <a href="tel:+36703187843" class="hidden sm:inline-flex btn btn-secondary text-sm px-4 py-2">
                +36 70 318 7843
            </a>
            <a href="/#kapcsolat" class="btn text-sm px-4 py-2">
                Ajánlatkérés
            </a>
        </div>
    </div>
</header>
