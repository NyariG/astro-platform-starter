---
import { Image } from 'astro:assets';
import myPhoto from '../assets/telefonalos2.png';

const name = "Nyári Terv";
const email = "info@nyariterv.hu";
const phone = "+36 70 318 7843";
---

<section id="kapcsolat" class="section bg-blue-50 border-t border-slate-100">
    <div class="container-custom">
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-2">
                <!-- Contact Info & Photo -->
                <div class="p-8 sm:p-12 bg-slate-50 flex flex-col justify-center">
                    <h2 class="text-3xl font-bold tracking-tight text-slate-900 mb-6">Vegye fel velünk a kapcsolatot!</h2>
                    <p class="text-slate-600 mb-8">
                        Kérjen ajánlatot vagy egyeztessen időpontot. Állunk rendelkezésére Győrben és vonzáskörzetében.
                    </p>

                    <div class="flex items-center gap-6 mb-8">
                        <div class="relative">
                            <Image src={myPhoto} alt={name} class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-md" />
                            <div class="absolute bottom-0 right-0 w-6 h-6 bg-green-500 border-2 border-white rounded-full"></div>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-slate-900">{name}</h3>
                            <p class="text-slate-500">Épületgépész tervező</p>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="bg-white p-3 rounded-lg text-primary shadow-sm">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wide">Email</h3>
                                <a href={`mailto:${email}`} class="text-lg text-slate-700 hover:text-primary transition">{email}</a>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-4">
                            <div class="bg-white p-3 rounded-lg text-primary shadow-sm">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wide">Telefon</h3>
                                <a href={`tel:${phone.replace(/\s/g, '')}`} class="text-lg text-slate-700 hover:text-primary transition">{phone}</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Form -->
                <div class="p-8 sm:p-12 bg-white">
                    <form action="https://formsubmit.co/a5c18b689fef0eb768998c1e3a6e292b" method="POST" class="space-y-6">
                        <input type="hidden" name="_subject" value="Új üzenet a weboldalról - Nyári Terv" />
                        <input type="hidden" name="_captcha" value="true" />
                        <input type="hidden" name="_template" value="table" />
                        <input type="text" name="_honey" style="display:none" />
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <div>
                                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">Név</label>
                                <input type="text" name="name" id="name" required class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm transition" placeholder="Az Ön neve" />
                            </div>
                            <div>
                                <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">Telefonszám</label>
                                <input type="tel" name="phone" id="phone" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm transition" placeholder="+36 20 123 4567" />
                            </div>
                        </div>

                        <div>
                            <label for="email" class="block text-sm font-medium text-slate-700 mb-2">Email cím</label>
                            <input type="email" name="email" id="email" required class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm transition" placeholder="pelda@email.com" />
                        </div>

                        <div>
                            <label for="message" class="block text-sm font-medium text-slate-700 mb-2">Üzenet</label>
                            <textarea name="message" id="message" rows="4" required class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary shadow-sm transition resize-none" placeholder="Miben segíthetünk?"></textarea>
                        </div>

                        <button type="submit" class="btn w-full py-3 text-base shadow-lg hover:shadow-xl transition-all">
                            Üzenet küldése
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
